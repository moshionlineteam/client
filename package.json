{
  "name": "moshi-online-client",
  "version": "3.0.0",
  "description": "Desktop client for moshionline.net",
  "main": "lib/main.js",
    "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:macos-x64": "electron-forge make --platform=darwin --arch=x64",
    "make:macos-arm64": "electron-forge make --platform=darwin --arch=arm64",
    "make:win32-x64": "electron-forge make --platform=win32 --arch=x64",
    "make:win32-ia32": "electron-forge make --platform=win32 --arch=ia32",
    "make:linux-x64": "electron-forge make --platform=linux --arch=x64",
    "make:linux-ia32": "electron-forge make --platform=linux --arch=ia32",
    "publish": "electron-forge publish",
    "publish-windows": "electron-forge publish",
    "publish-mac": "electron-forge publish --arch=x64",
    "publish-git": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "moshionline",
            "authors": "Moshi Online Team",
            "setupIcon": "./icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ]
    }
  },
  "bugs": {
    "url": "https://github.com/moshionlineteam"
  },
  "homepage": "https://github.com/moshionlineteam/client#readme",
  "repository": "https://github.com/moshionlineteam/client",
  "author": "Moshi Online Team",
  "license": "CC0-1.0",
  "dependencies": {
    "axios": "^1.13.1",
    "discord-rpc": "^4.0.1",
    "electron-forge": "^5.2.4",
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.4.2",
    "@electron-forge/maker-appx": "^6.0.0-beta.54",
    "@electron-forge/maker-deb": "^6.4.2",
    "@electron-forge/maker-dmg": "^6.0.0-beta.54",
    "@electron-forge/maker-flatpak": "^6.0.0-beta.64",
    "@electron-forge/maker-rpm": "^6.4.2",
    "@electron-forge/maker-squirrel": "^6.4.2",
    "@electron-forge/maker-zip": "^6.4.2",
    "@electron-forge/publisher-github": "^6.0.0-beta.54",
    "electron": "^11.5.0"
  },
"build": {
  "publish": [
    {
      "provider": "github",
      "releaseType": "draft"
    }
  ],
  "appId": "com.moshi-online.desktop",
  "productName": "Moshi Online Desktop",
  "asar": false,
  "mac": {
    "icon": "./icon.icns",
    "category": "public.app-category.games",
    "target": [
      "dmg",
      "zip"
    ]
  },

  "win": {
    "icon": "./icon.png",
    "target": [
      "nsis",
      "exe"
    ]
  },

  "linux": {
    "icon": "./icon.png",
    "category": "Game",
    "target": [
      "deb",
      "rpm",
      "AppImage"
    ]
  }
}

}
